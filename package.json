{
  "name": "nulladdict.com",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro build && astro preview",
    "astro": "astro",
    "upgrade": "npx npm-check@latest -u && npm update",
    "fix": "oxlint --fix && oxfmt --write",
    "check": "oxlint --deny-warnings && oxfmt --check"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.1",
    "lint-staged": "^17.0.3",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.90.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": [
      "npx oxlint --fix --no-error-on-unmatched-pattern",
      "npx oxfmt --write --no-error-on-unmatched-pattern"
    ]
  }
}
